<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:strokeColor="#D45D3B">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/imageCover"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:src="@drawable/mountain"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/itineraryType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="20dp"
            android:text="Economique"
            android:textColor="#2D3142"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageCover" />

        <LinearLayout
            android:id="@+id/badgeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/itineraryType">

            <androidx.cardview.widget.CardView
                android:id="@+id/badgeTime"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#F4F1ED"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/iconTime"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/outline_timelapse_24"
                        app:tint="#D45D3B" />
                    <TextView
                        android:id="@+id/itineraryTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="45 MIN"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2D3142" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/badgeDistance"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                app:cardBackgroundColor="#F4F1ED"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/iconDistance"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/outline_conversion_path_24"
                        app:tint="#D45D3B" />
                    <TextView
                        android:id="@+id/itineraryDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="3.2KM"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2D3142" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/badgePrice"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#F4F1ED"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/iconPrice"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/outline_dollar_24"
                        app:tint="#D45D3B" />
                    <TextView
                        android:id="@+id/itineraryPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="GRATUIT"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2D3142" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChoisir"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="CHOISIR"
            android:textColor="#2D3142"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#EAE4DD"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/badgeRow" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>